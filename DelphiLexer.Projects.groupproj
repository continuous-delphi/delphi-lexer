    <Target Name="DelphiLexer_Tests:Make">
        <MSBuild Projects="test\DelphiLexer.Tests.dproj" Targets="Make"/>
    </Target>
    <Target Name="Build">
        <CallTarget Targets="DelphiLexer_TokenDump;DelphiLexer_TokenStats;DelphiLexer_TokenCompare;DelphiLexer_Tests"/>
    </Target>
    <Target Name="Clean">
        <CallTarget Targets="DelphiLexer_TokenDump:Clean;DelphiLexer_TokenStats:Clean;DelphiLexer_TokenCompare:Clean;DelphiLexer_Tests:Clean"/>
    </Target>
    <Target Name="Make">
        <CallTarget Targets="DelphiLexer_TokenDump:Make;DelphiLexer_TokenStats:Make;DelphiLexer_TokenCompare:Make;DelphiLexer_Tests:Make"/>
    </Target>
    <Import Project="$(BDS)\Bin\CodeGear.Group.Targets" Condition="Exists('$(BDS)\Bin\CodeGear.Group.Targets')"/>
