<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <ProjectGuid>{DEC63F66-61A8-41AA-926B-84A2FF01CBDE}</ProjectGuid>
    </PropertyGroup>
    <ItemGroup>
        <Projects Include="projects\TokenDump\DelphiLexer.TokenDump.dproj">
            <Dependencies/>
        </Projects>
        <Projects Include="projects\TokenStats\DelphiLexer.TokenStats.dproj">
            <Dependencies/>
        </Projects>
        <Projects Include="projects\TokenCompare\DelphiLexer.TokenCompare.dproj">
            <Dependencies/>
        </Projects>
        <Projects Include="test\DelphiLexer.Tests.dproj">
            <Dependencies/>
        </Projects>
    </ItemGroup>
    <ProjectExtensions>
        <Borland.Personality>Default.Personality.12</Borland.Personality>
        <Borland.ProjectType/>
        <BorlandProject>
            <Default.Personality/>
        </BorlandProject>
    </ProjectExtensions>
    <Target Name="DelphiLexer_TokenDump">
        <MSBuild Projects="projects\TokenDump\DelphiLexer.TokenDump.dproj"/>
    </Target>
    <Target Name="DelphiLexer_TokenDump:Clean">
        <MSBuild Projects="projects\TokenDump\DelphiLexer.TokenDump.dproj" Targets="Clean"/>
    </Target>
    <Target Name="DelphiLexer_TokenDump:Make">
        <MSBuild Projects="projects\TokenDump\DelphiLexer.TokenDump.dproj" Targets="Make"/>
    </Target>
    <Target Name="DelphiLexer_TokenStats">
        <MSBuild Projects="projects\TokenStats\DelphiLexer.TokenStats.dproj"/>
    </Target>
    <Target Name="DelphiLexer_TokenStats:Clean">
        <MSBuild Projects="projects\TokenStats\DelphiLexer.TokenStats.dproj" Targets="Clean"/>
    </Target>
    <Target Name="DelphiLexer_TokenStats:Make">
        <MSBuild Projects="projects\TokenStats\DelphiLexer.TokenStats.dproj" Targets="Make"/>
    </Target>
    <Target Name="DelphiLexer_TokenCompare">
        <MSBuild Projects="projects\TokenCompare\DelphiLexer.TokenCompare.dproj"/>
    </Target>
    <Target Name="DelphiLexer_TokenCompare:Clean">
        <MSBuild Projects="projects\TokenCompare\DelphiLexer.TokenCompare.dproj" Targets="Clean"/>
    </Target>
